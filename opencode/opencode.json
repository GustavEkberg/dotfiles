{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "file:///Users/abraxas/.config/opencode/plugins/opencode-anthropic-auth.mjs"
  ],
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "bash": {
      "supabase reset": "deny",
      "supabase reset *": "deny",
      "supabase db reset": "deny",
      "supabase db reset *": "deny",
      "supabase function deploy": "deny",
      "supabase function deploy *": "deny",
      "supabase functions deploy": "deny",
      "supabase functions deploy *": "deny"
    }
  }
}
