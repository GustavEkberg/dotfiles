{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "file:///Users/abraxas/.config/opencode/plugins/opencode-anthropic-auth.mjs"
  ],
  "model": "anthropic/claude-opus-4-7",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "external_directory": {
      "/tmp": "allow",
      "/tmp/*": "allow"
    },
    "edit": {
      "/tmp/*": "allow"
    },
    "bash": {
      "supabase reset": "deny",
      "supabase reset *": "deny",
      "supabase db reset": "deny",
      "supabase db reset *": "deny",
      "supabase function deploy": "deny",
      "supabase function deploy *": "deny",
      "supabase functions deploy": "deny",
      "supabase functions deploy *": "deny",
      "pnpm dev": "deny",
      "pnpm dev *": "deny",
      "pnpm run dev": "deny",
      "pnpm run dev *": "deny",
      "npm run dev": "deny",
      "npm run dev *": "deny",
      "npm dev": "deny",
      "npm dev *": "deny",
      "yarn dev": "deny",
      "yarn dev *": "deny",
      "yarn run dev": "deny",
      "yarn run dev *": "deny",
      "bun dev": "deny",
      "bun dev *": "deny",
      "bun run dev": "deny",
      "bun run dev *": "deny",
      "npx next dev": "deny",
      "npx next dev *": "deny",
      "npx vite": "deny",
      "npx vite *": "deny"
    }
  }
}
