{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "file:///Users/abraxas/.config/opencode/plugins/opencode-anthropic-auth.mjs"
  ],
  "model": "openai/gpt-5.5",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "medium"
          }
        }
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true,
      "oauth": {
        "clientId": "{env:FIGMA_MCP_CLIENT_ID}",
        "clientSecret": "{env:FIGMA_MCP_CLIENT_SECRET}"
      },
      "timeout": 30000
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "external_directory": {
      "/tmp": "allow",
      "/tmp/*": "allow"
    },
    "edit": {
      "/tmp/*": "allow"
    },
    "bash": {
      "supabase reset": "deny",
      "supabase reset *": "deny",
      "supabase db reset": "deny",
      "supabase db reset *": "deny",
      "supabase function deploy": "deny",
      "supabase function deploy *": "deny",
      "supabase functions deploy": "deny",
      "supabase functions deploy *": "deny",
      "pnpm dev": "deny",
      "pnpm dev *": "deny",
      "pnpm run dev": "deny",
      "pnpm run dev *": "deny",
      "npm run dev": "deny",
      "npm run dev *": "deny",
      "npm dev": "deny",
      "npm dev *": "deny",
      "yarn dev": "deny",
      "yarn dev *": "deny",
      "yarn run dev": "deny",
      "yarn run dev *": "deny",
      "bun dev": "deny",
      "bun dev *": "deny",
      "bun run dev": "deny",
      "bun run dev *": "deny",
      "npx next dev": "deny",
      "npx next dev *": "deny",
      "npx vite": "deny",
      "npx vite *": "deny",
      "ruby": "deny",
      "ruby *": "deny",
      "irb": "deny",
      "irb *": "deny",
      "gem": "deny",
      "gem *": "deny",
      "rake": "deny",
      "rake *": "deny",
      "bundle": "deny",
      "bundle *": "deny",
      "bundler": "deny",
      "bundler *": "deny",
      "erb": "deny",
      "erb *": "deny",
      "perl": "deny",
      "perl *": "deny",
      "php": "deny",
      "php *": "deny",
      "osascript": "deny",
      "osascript *": "deny",
      "lua": "deny",
      "lua *": "deny",
      "luajit": "deny",
      "luajit *": "deny",
      "tclsh": "deny",
      "tclsh *": "deny",
      "groovy": "deny",
      "groovy *": "deny",
      "Rscript": "deny",
      "Rscript *": "deny"
    }
  }
}
